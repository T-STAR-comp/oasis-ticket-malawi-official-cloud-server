PORT=8000
NODE_ENV=development

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=ticket_malawi

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:8080,http://localhost:8090

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ticketmalawi.local
ADMIN_PASSWORD=password
ADMIN_FULL_NAME=System Administrator

SMTP_SECURE=false
MAIL_MAILER=smtp
MAIL_HOST=mail.spacemail.com
MAIL_PORT=587
MAIL_USERNAME=hello@emsoasis.online
MAIL_PASSWORD=s7cReGKL.FhPrMC
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@emsoasis.online
MAIL_FROM_NAME=Oasis-ticket-malawi

# PayChangu (mobile money). PAYCHANGU_MOCK=false with a live key for real charges.
PAYCHANGU_SECRET_KEY=
PAYCHANGU_BASE_URL=https://api.paychangu.com
PAYCHANGU_MOCK=false
PAYCHANGU_MOCK_AMOUNT_MWK=50
PAYCHANGU_MOCK_SUCCESS_DELAY_MS=5000
PAYMENT_POLL_INTERVAL_MS=8000
PAYMENT_PENDING_TIMEOUT_MS=300000
PAYMENT_VERIFY_GRACE_MS=90000

# Listing images (cPanel: folder sibling to the Node app, not inside it)
IMAGE_BUCKET_DIR=../image-bucket-folder
# Public URL origin for stored images (API host in dev; your domain in production)
IMAGE_PUBLIC_ORIGIN=http://localhost:8000
# Set false when Apache/nginx serves image-bucket-folder directly
IMAGE_SERVE_FROM_API=true
