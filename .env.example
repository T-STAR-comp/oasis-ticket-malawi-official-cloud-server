PORT=8000
NODE_ENV=development

# Production entry: server.cjs (CommonJS bootstrap → dist/index.js ESM app)
# cPanel / Passenger: set startup file to server.cjs

# Serve React build from public/ (auto-enabled when NODE_ENV=production)
SERVE_FRONTEND=false

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=ticket_malawi

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Split dev: Vite :8080 + API :8000. Unified prod: your public URL (e.g. https://tickets.example.com)
CORS_ORIGINS=http://localhost:8080,http://localhost:8000

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ticketmalawi.local
ADMIN_PASSWORD=password
ADMIN_FULL_NAME=System Administrator

SMTP_SECURE=true
MAIL_MAILER=smtp
MAIL_HOST=mail.spacemail.com
MAIL_PORT=465
MAIL_USERNAME=hello@ticketmalawi.com
MAIL_PASSWORD=eS$hwhpV5$X$CnE
MAIL_ENCRYPTION=SSL
MAIL_FROM_ADDRESS=hello@ticketmalawi.com
MAIL_FROM_NAME=Oasis-ticket-malawi

# PayChangu (mobile money). PAYCHANGU_MOCK=false with a live key for real charges.
PAYCHANGU_SECRET_KEY=
PAYCHANGU_BASE_URL=https://api.paychangu.com
PAYCHANGU_MOCK=false
PAYCHANGU_MOCK_AMOUNT_MWK=50
PAYCHANGU_MOCK_SUCCESS_DELAY_MS=5000
PAYMENT_POLL_INTERVAL_MS=8000
PAYMENT_PENDING_TIMEOUT_MS=300000
PAYMENT_VERIFY_GRACE_MS=90000

# Platform checkout service fee (% of ticket price) — charged to buyer at checkout only
PLATFORM_SERVICE_FEE_PERCENT=5
# Referrer payout platform fee (% of withdrawable amount)
REFERRAL_PAYOUT_FEE_PERCENT=2

# Auth: legacy | firebase | both (default both)
AUTH_PROVIDER=both
FIREBASE_AUTH_ENABLED=true
FIREBASE_PROJECT_ID=ticket-malawi
# Service account JSON string from Firebase console (required for reliable token verification in production)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Listing images (cPanel: folder sibling to the Node app, not inside it)
IMAGE_BUCKET_DIR=../image-bucket-folder
# Public URL origin for stored images (API host in dev; your domain in production)
# Required for social share previews (og:image) — must match your live site URL.
# Same host as the Node app when SERVE_FRONTEND=true
IMAGE_PUBLIC_ORIGIN=http://localhost:8000
# Set false when Apache/nginx serves image-bucket-folder directly
IMAGE_SERVE_FROM_API=true
